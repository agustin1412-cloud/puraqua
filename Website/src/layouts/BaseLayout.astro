---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "Puraqua — Equipos de purificación de agua por ósmosis inversa para hogares y empresas en Uruguay. Agua pura, precio accesible.",
  ogImage = "/images/logo.png",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? "https://puraqua.com.uy");
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | Puraqua`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="es_UY" />

    <link rel="icon" type="image/png" href="/images/logo.png" />
    <title>{title} | Puraqua</title>

    <!-- Tipografía: Plus Jakarta Sans + DM Sans -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;700;800&family=DM+Sans:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-background text-text-dark antialiased">
    <slot />
  </body>
</html>

<style is:global>
  @import "../styles/global.css";

  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-display);
  }

  body {
    font-family: var(--font-sans);
  }
</style>
