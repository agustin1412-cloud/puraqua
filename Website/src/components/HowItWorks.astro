---
const steps = [
  {
    number: "01",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 10V7"/></svg>`,
    title: "Pre-filtración",
    desc: "Los primeros filtros retienen sedimentos, óxido, partículas y cloro. El agua entra limpia a la membrana.",
  },
  {
    number: "02",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
    title: "Membrana de ósmosis",
    desc: "La membrana de 0.0001 micrones elimina hasta el 99% de contaminantes: metales pesados, bacterias, microplásticos y más.",
  },
  {
    number: "03",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>`,
    title: "Post-filtración y mineralización",
    desc: "El último filtro de carbón activo mejora el sabor. El mineralizador devuelve los minerales esenciales al agua purificada.",
  },
];
---

<section class="py-20 bg-surface">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-14">
      <p class="text-cyan-accent font-semibold uppercase tracking-widest text-sm mb-3">Cómo funciona</p>
      <h2 class="font-display text-3xl sm:text-4xl font-extrabold text-blue-dark mb-4">
        Tecnología probada, resultado simple
      </h2>
      <p class="text-text-dark/60 text-lg max-w-xl mx-auto">
        La ósmosis inversa es el método de purificación más efectivo disponible. Lo mismo que usan las plantas embotelladoras, ahora en tu canilla.
      </p>
    </div>

    <!-- Pasos con línea conectora -->
    <div class="relative">
      <!-- Línea conectora (desktop) -->
      <div class="hidden md:block absolute top-10 left-1/6 right-1/6 h-0.5 bg-gradient-to-r from-cyan-accent/30 via-cyan-accent to-cyan-accent/30" aria-hidden="true"></div>

      <div class="grid md:grid-cols-3 gap-8">
        {steps.map((step) => (
          <div class="relative flex flex-col items-center text-center">
            <!-- Número + icono -->
            <div class="relative mb-6">
              <div class="w-20 h-20 bg-white border-2 border-cyan-accent/30 rounded-2xl flex items-center justify-center text-cyan-accent shadow-lg shadow-cyan-accent/10">
                <Fragment set:html={step.icon} />
              </div>
              <span class="absolute -top-2 -right-2 bg-cyan-accent text-white text-xs font-bold w-6 h-6 rounded-full flex items-center justify-center">
                {step.number.slice(-1)}
              </span>
            </div>
            <h3 class="font-display font-bold text-xl text-blue-dark mb-3">{step.title}</h3>
            <p class="text-text-dark/65 text-sm leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Resultado final -->
    <div class="mt-14 bg-gradient-to-r from-blue-dark to-blue-medium rounded-2xl p-8 text-white text-center">
      <p class="font-display font-extrabold text-2xl mb-2">Resultado: agua pura directo de tu canilla</p>
      <p class="text-white/70">Sin garrafones, sin plástico, sin preocupaciones. Solo agua limpia, todos los días.</p>
    </div>
  </div>
</section>
