---
const badges = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
    title: "12 meses de garantía",
    desc: "Si algo falla, lo resolvemos.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>`,
    title: "Envíos a todo Uruguay",
    desc: "Montevideo y el interior del país.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>`,
    title: "Pago seguro",
    desc: "MercadoPago con todas las tarjetas.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>`,
    title: "Soporte por WhatsApp",
    desc: "Antes y después de la compra.",
  },
];
---

<section class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-14">
      <p class="text-cyan-accent font-semibold uppercase tracking-widest text-sm mb-3">Confianza</p>
      <h2 class="font-display text-3xl sm:text-4xl font-extrabold text-blue-dark mb-4">
        Comprás con tranquilidad
      </h2>
      <p class="text-text-dark/60 max-w-md mx-auto">
        Cada equipo Puraqua viene respaldado por garantía, soporte real y envío a todo el país.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-16">
      {badges.map((b) => (
        <div class="text-center p-6">
          <div class="inline-flex items-center justify-center w-16 h-16 bg-surface rounded-2xl text-cyan-accent mb-4">
            <Fragment set:html={b.icon} />
          </div>
          <h3 class="font-display font-bold text-blue-dark mb-1">{b.title}</h3>
          <p class="text-sm text-text-dark/60">{b.desc}</p>
        </div>
      ))}
    </div>

    <!-- Placeholder testimonios -->
    <div class="bg-surface rounded-2xl p-8 border border-blue-sky/20 text-center">
      <p class="text-4xl mb-4">💬</p>
      <p class="font-display font-bold text-blue-dark text-xl mb-2">Próximamente: testimonios de clientes</p>
      <p class="text-text-dark/60 text-sm max-w-md mx-auto">
        ¿Ya tenés un equipo Puraqua? Escribinos por WhatsApp y contanos tu experiencia.
      </p>
    </div>
  </div>
</section>
