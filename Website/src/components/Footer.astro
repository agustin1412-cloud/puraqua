---
import { config, whatsappURL } from '../data/config';

const waURL = whatsappURL();
---

<footer class="footer" role="contentinfo">
  <div class="container">
    <div class="footer__grid">
      <div>
        <div class="footer__brand-logo">PURA<span>QUA</span></div>
        <div class="footer__brand-tag">{config.tagline}</div>
        <p class="footer__desc">Equipos de ósmosis inversa de calidad premium para hogares y empresas de Uruguay. Agua pura, precio justo.</p>
      </div>
      <div>
        <div class="footer__h">Navegación</div>
        <nav class="footer__links" aria-label="Footer">
          <a href="#inicio">Inicio</a>
          <a href="#producto">Producto</a>
          <a href="#beneficios">Beneficios</a>
          <a href="#comparativa">Comparativa</a>
          <a href="#faq">FAQ</a>
          <a href="#contacto">Contacto</a>
        </nav>
      </div>
      <div>
        <div class="footer__h">Contacto</div>
        <div class="footer__contact-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="white" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M11.995 0C5.375 0 0 5.372 0 11.988c0 2.113.555 4.094 1.523 5.812L0 24l6.335-1.652A11.956 11.956 0 0011.995 24C18.617 24 24 18.628 24 12.012 24 5.372 18.617 0 11.995 0zm0 21.81c-1.942 0-3.744-.52-5.295-1.42l-.379-.224-3.933 1.025 1.051-3.83-.248-.393A9.714 9.714 0 012.19 12.01c0-5.41 4.404-9.81 9.805-9.81 5.404 0 9.807 4.4 9.807 9.81 0 5.406-4.403 9.81-9.807 9.81z"/></svg>
          <a href={waURL} target="_blank" rel="noopener" class="footer__contact-link">+598 91 410 111</a>
        </div>
        <div class="footer__contact-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke="white" stroke-width="1.5"/><path d="M22 6l-10 7L2 6" stroke="white" stroke-width="1.5" stroke-linecap="round"/></svg>
          <a href={`mailto:${config.email}`} class="footer__contact-link">{config.email}</a>
        </div>
        <div class="footer__contact-item footer__location">
          Uruguay · Envíos a todo el país
        </div>
      </div>
    </div>
    <div class="footer__bar">
      <span>© 2026 PURAQUA. Todos los derechos reservados.</span>
      <span>Hecho con ❤ en Uruguay</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #0a1e30; color: rgba(255,255,255,.6);
    padding: 56px 0 32px;
  }
  .footer__grid {
    display: grid; grid-template-columns: 1.5fr 1fr 1fr; gap: 48px; margin-bottom: 48px;
  }
  .footer__brand-logo {
    font-family: var(--font-head); font-weight: 800; font-size: 1.3rem;
    color: var(--white); letter-spacing: -.03em; margin-bottom: 6px;
  }
  .footer__brand-logo span { color: var(--cyan); }
  .footer__brand-tag { font-size: .7rem; letter-spacing: .12em; text-transform: uppercase; color: rgba(255,255,255,.7); margin-bottom: 16px; }
  .footer__desc { font-size: .85rem; line-height: 1.65; max-width: 260px; }
  .footer__h { font-family: var(--font-head); font-size: .8rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: rgba(255,255,255,.75); margin-bottom: 16px; }
  .footer__links { display: flex; flex-direction: column; gap: 10px; }
  .footer__links a { font-size: .875rem; color: rgba(255,255,255,.55); transition: color .15s; }
  .footer__links a:hover { color: var(--white); }
  .footer__contact-item { display: flex; align-items: center; gap: 10px; font-size: .875rem; margin-bottom: 12px; }
  .footer__contact-item svg { flex-shrink: 0; opacity: .5; }
  .footer__contact-link { color: rgba(255,255,255,.55); transition: color .15s; }
  .footer__contact-link:hover { color: var(--white); }
  .footer__location { font-size: .8rem; opacity: .4; }
  .footer__bar {
    border-top: 1px solid rgba(255,255,255,.08);
    padding-top: 24px; display: flex; justify-content: space-between;
    align-items: center; flex-wrap: wrap; gap: 12px;
    font-size: .8rem; color: rgba(255,255,255,.65);
  }
</style>
