---
const whatsappURL = "https://wa.me/59899000000?text=Hola%2C%20quiero%20información%20sobre%20el%20equipo%20Puraqua";
const mpURL = "#producto";
---

<section class="py-24 bg-blue-dark relative overflow-hidden">
  <!-- Fondo atmosférico -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <svg class="absolute bottom-0 left-0 w-full opacity-[0.06]" viewBox="0 0 1440 200" preserveAspectRatio="none">
      <path fill="#00c8e0" d="M0,64L80,74.7C160,85,320,107,480,101.3C640,96,800,64,960,58.7C1120,53,1280,75,1360,85.3L1440,96L1440,200L1360,200C1280,200,1120,200,960,200C800,200,640,200,480,200C320,200,160,200,80,200L0,200Z"></path>
    </svg>
  </div>

  <div class="relative max-w-3xl mx-auto px-6 text-center">
    <p class="text-cyan-accent font-semibold uppercase tracking-widest text-sm mb-4">¿Listo para dar el paso?</p>
    <h2 class="font-display text-3xl sm:text-5xl font-extrabold text-white mb-6 leading-tight">
      Empezá a tomar agua<br />
      <span class="text-cyan-accent">de verdad</span> hoy
    </h2>
    <p class="text-white/70 text-lg mb-10 max-w-lg mx-auto">
      Escribinos por WhatsApp y te asesoramos sin compromiso. Respondemos rápido, todos los días.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href={whatsappURL}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-center gap-2 bg-cyan-accent hover:bg-blue-light text-white font-bold px-10 py-4 rounded-xl transition-all hover:scale-[1.02] shadow-xl shadow-cyan-accent/30 text-lg"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Consultar por WhatsApp
      </a>
      <a
        href={mpURL}
        class="flex items-center justify-center border-2 border-white/30 text-white hover:border-white hover:bg-white/10 font-semibold px-10 py-4 rounded-xl transition-all text-lg"
      >
        Ver el equipo
      </a>
    </div>
  </div>
</section>
