---
import { whatsappURL } from '../data/config';

const waURL = whatsappURL("Hola, quiero información sobre el equipo Puraqua");
---

<section class="cta-final" aria-labelledby="cta-final-h">
  <div class="cta-final__bg" aria-hidden="true">
    <svg viewBox="0 0 1440 200" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path fill="#00c8e0" opacity=".06" d="M0,64L80,74.7C160,85,320,107,480,101.3C640,96,800,64,960,58.7C1120,53,1280,75,1360,85.3L1440,96L1440,200L1360,200C1280,200,1120,200,960,200C800,200,640,200,480,200C320,200,160,200,80,200L0,200Z"/>
    </svg>
  </div>
  <div class="cta-final__inner">
    <p class="section-label" style="color:var(--cyan);">¿Listo para dar el paso?</p>
    <h2 class="section-h2 cta-final__h2" id="cta-final-h">
      Empezá a tomar agua<br/><span style="color:var(--cyan);">de verdad</span> hoy
    </h2>
    <p class="cta-final__sub">
      Escribinos por WhatsApp y te asesoramos sin compromiso. Respondemos rápido, todos los días.
    </p>
    <div class="cta-final__actions">
      <a href={waURL} class="btn-primary cta-final__btn-primary" target="_blank" rel="noopener">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M11.995 0C5.375 0 0 5.372 0 11.988c0 2.113.555 4.094 1.523 5.812L0 24l6.335-1.652A11.956 11.956 0 0011.995 24C18.617 24 24 18.628 24 12.012 24 5.372 18.617 0 11.995 0zm0 21.81c-1.942 0-3.744-.52-5.295-1.42l-.379-.224-3.933 1.025 1.051-3.83-.248-.393A9.714 9.714 0 012.19 12.01c0-5.41 4.404-9.81 9.805-9.81 5.404 0 9.807 4.4 9.807 9.81 0 5.406-4.403 9.81-9.807 9.81z"/></svg>
        Consultar por WhatsApp
      </a>
      <a href="#producto" class="cta-final__btn-outline">
        Ver el equipo
      </a>
    </div>
  </div>
</section>

<style>
  .cta-final {
    position: relative; overflow: hidden;
    background: var(--blue-dark);
    padding: 96px 0;
  }
  .cta-final__bg {
    position: absolute; inset: 0; pointer-events: none;
  }
  .cta-final__bg svg { position: absolute; bottom: 0; left: 0; width: 100%; }
  .cta-final__inner {
    position: relative; z-index: 1; text-align: center;
    max-width: 720px; margin: 0 auto; padding: 0 24px;
  }
  .cta-final__h2 { color: var(--white); text-align: center; margin-bottom: 20px; }
  .cta-final__sub {
    color: rgba(255,255,255,.7); font-size: 1.05rem; margin-bottom: 40px;
    max-width: 480px; margin-left: auto; margin-right: auto;
  }
  .cta-final__actions { display: flex; flex-wrap: wrap; gap: 14px; justify-content: center; }
  .cta-final__btn-primary { font-size: 1.05rem; padding: 16px 32px; }
  .cta-final__btn-outline {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: var(--font-head); font-size: 1.05rem; font-weight: 600;
    color: var(--white); border: 1.5px solid rgba(255,255,255,.3);
    padding: 16px 32px; border-radius: 100px;
    transition: background .15s, border-color .15s, transform .15s;
    white-space: nowrap;
  }
  .cta-final__btn-outline:hover {
    border-color: var(--white); background: rgba(255,255,255,.1);
    transform: translateY(-1px);
  }
</style>
