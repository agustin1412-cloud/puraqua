---
// No external data needed
---

<section class="comparison" id="comparativa" aria-labelledby="comp-h">
  <div class="container">
    <div class="comparison__header">
      <p class="section-label fade-up" style="color:var(--cyan);">Comparativa</p>
      <h2 class="section-h2 fade-up" id="comp-h">¿Por qué ósmosis inversa?</h2>
      <p style="color:var(--text-muted);margin-top:12px;font-size:1rem;">Hay varias formas de mejorar el agua que tomás. Esta es la comparativa honesta.</p>
    </div>
    <div class="comparison__wrap fade-up">
      <table class="comparison__table" role="table" aria-label="Comparativa de opciones de agua">
        <thead>
          <tr>
            <th scope="col"></th>
            <th scope="col" class="th-puraqua">Puraqua Pro</th>
            <th scope="col">Agua embotellada</th>
            <th scope="col">Filtro de jarra</th>
            <th scope="col">Sin filtrar</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Costo mensual aprox.</td>
            <td class="td-puraqua td-highlight">~$200 UYU</td>
            <td class="td-muted">~$2.000-5.000 UYU</td>
            <td class="td-muted">~$400 UYU</td>
            <td class="td-muted">$0 pero...</td>
          </tr>
          <tr>
            <td>Elimina cloro</td>
            <td class="td-puraqua"><span class="check">✓</span></td>
            <td><span class="check">✓</span></td>
            <td><span class="partial">Parcial</span></td>
            <td><span class="cross">✗</span></td>
          </tr>
          <tr>
            <td>Elimina metales pesados</td>
            <td class="td-puraqua"><span class="check">✓</span></td>
            <td><span class="check">✓</span></td>
            <td><span class="cross">✗</span></td>
            <td><span class="cross">✗</span></td>
          </tr>
          <tr>
            <td>Elimina bacterias</td>
            <td class="td-puraqua"><span class="check">✓</span></td>
            <td><span class="check">✓</span></td>
            <td><span class="cross">✗</span></td>
            <td><span class="cross">✗</span></td>
          </tr>
          <tr>
            <td>Disponibilidad</td>
            <td class="td-puraqua td-sm-bold">24/7 en tu canilla</td>
            <td class="td-muted">Hay que comprar</td>
            <td class="td-muted">24/7 (lento)</td>
            <td class="td-muted">24/7</td>
          </tr>
          <tr>
            <td>Residuo plástico</td>
            <td class="td-puraqua"><span class="check">Ninguno</span></td>
            <td><span class="cross">Alto</span></td>
            <td style="color:var(--text-muted);">Bajo</td>
            <td><span class="check">Ninguno</span></td>
          </tr>
          <tr>
            <td>Mantenimiento</td>
            <td class="td-puraqua td-sm">Filtros 1x/año</td>
            <td class="td-muted">Ninguno</td>
            <td class="td-muted">Filtros frecuentes</td>
            <td class="td-muted">Ninguno</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .comparison { padding: 88px 0; background: var(--surface); }
  .comparison__header { text-align: center; max-width: 600px; margin: 0 auto 48px; }
  .comparison__wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; }
  .comparison__table {
    width: 100%; min-width: 640px; border-collapse: separate; border-spacing: 0;
    border-radius: var(--radius-lg); overflow: hidden;
    box-shadow: var(--shadow-md);
  }
  .comparison__table thead th {
    padding: 20px 24px; font-family: var(--font-head); font-size: .85rem; font-weight: 700;
    text-align: center; white-space: nowrap;
  }
  .comparison__table thead th:first-child { text-align: left; background: var(--white); color: var(--text-muted); }
  .comparison__table thead .th-puraqua { background: var(--blue-dark); color: var(--white); }
  .comparison__table thead th:not(:first-child):not(.th-puraqua) { background: #e8f0f7; color: var(--text-muted); }
  .comparison__table tbody td {
    padding: 16px 24px; font-size: .875rem; text-align: center;
    border-top: 1px solid var(--border); background: var(--white);
  }
  .comparison__table tbody td:first-child {
    text-align: left; font-weight: 500; color: var(--text); background: var(--white);
  }
  .comparison__table tbody .td-puraqua { background: rgba(26,58,92,.04); }
  .comparison__table tbody tr:last-child td:first-child { border-radius: 0 0 0 var(--radius-lg); }
  .comparison__table tbody tr:last-child td:last-child { border-radius: 0 0 var(--radius-lg) 0; }
  .td-highlight { font-weight: 600; color: var(--success); }
  .td-muted { font-size: .82rem; color: var(--text-muted); }
  .td-sm { font-size: .82rem; }
  .td-sm-bold { font-size: .82rem; font-weight: 600; }
  .check { color: var(--success); }
  .cross { color: #dc2626; }
  .partial { color: #f59e0b; }
</style>
