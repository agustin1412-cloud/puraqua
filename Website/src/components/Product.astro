---
import { product } from "../data/product";
---

<section id="producto" class="py-20 bg-background">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-14">
      <p class="text-cyan-accent font-semibold uppercase tracking-widest text-sm mb-3">El producto</p>
      <h2 class="font-display text-3xl sm:text-4xl font-extrabold text-blue-dark">
        {product.name}
      </h2>
    </div>

    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Imagen -->
      <div class="flex justify-center">
        <div class="relative">
          <div class="absolute inset-0 bg-gradient-to-br from-cyan-accent/15 to-blue-light/15 rounded-3xl blur-3xl scale-110"></div>
          <div class="relative bg-white rounded-3xl p-10 shadow-2xl border border-surface">
            <img
              src="/images/logo.png"
              alt={product.name}
              class="w-72 h-72 object-contain mx-auto"
            />
          </div>
        </div>
      </div>

      <!-- Info -->
      <div>
        <p class="text-text-dark/70 text-lg leading-relaxed mb-6">{product.description}</p>

        <!-- Características -->
        <ul class="space-y-3 mb-8">
          {product.features.map((feature) => (
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-success mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
              </svg>
              <span class="text-text-dark text-sm">{feature}</span>
            </li>
          ))}
        </ul>

        <!-- Precio y CTAs -->
        <div class="bg-surface rounded-2xl p-6 border border-blue-sky/30">
          <div class="flex items-baseline gap-2 mb-1">
            <span class="font-display font-extrabold text-4xl text-blue-dark">{product.price.display}</span>
          </div>
          <p class="text-text-dark/50 text-sm mb-6">Precio final, sin cargos ocultos. Incluye envío a Montevideo.</p>

          <div class="flex flex-col sm:flex-row gap-3">
            <a
              href={product.whatsappURL}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center gap-2 bg-cyan-accent hover:bg-blue-light text-white font-bold px-6 py-3.5 rounded-xl transition-all hover:scale-[1.02] shadow-lg shadow-cyan-accent/25 flex-1 text-center"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Comprar por WhatsApp
            </a>
            <a
              href="#faq"
              class="flex items-center justify-center border-2 border-blue-dark text-blue-dark hover:bg-blue-dark hover:text-white font-semibold px-6 py-3.5 rounded-xl transition-all"
            >
              Ver preguntas frecuentes
            </a>
          </div>
        </div>

        <!-- Qué incluye -->
        <div class="mt-6">
          <p class="text-xs font-semibold text-text-dark/50 uppercase tracking-widest mb-3">Incluye</p>
          <div class="flex flex-wrap gap-2">
            {product.includes.map((item) => (
              <span class="text-xs bg-surface border border-blue-sky/30 text-text-dark/70 px-3 py-1 rounded-full">{item}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
