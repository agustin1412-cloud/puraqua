---
import { product } from '../data/product';
import { whatsappURL } from '../data/config';

const buyURL = whatsappURL("Hola, quiero comprar un equipo Puraqua Pro");
---

<section class="product" id="producto" aria-labelledby="product-h">
  <div class="container">
    <div class="product__inner">
      <div class="product__visual fade-up">
        <div class="product__img-wrap">
          <!-- Product illustration SVG -->
          <svg viewBox="0 0 320 400" xmlns="http://www.w3.org/2000/svg" width="320" aria-label="Equipo Puraqua Pro" role="img">
            <defs>
              <linearGradient id="p1" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="#2c6faa"/>
                <stop offset="100%" stop-color="#1a3a5c"/>
              </linearGradient>
              <linearGradient id="p2" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="rgba(255,255,255,.2)"/>
                <stop offset="100%" stop-color="rgba(255,255,255,.02)"/>
              </linearGradient>
            </defs>
            <rect x="60" y="60" width="200" height="260" rx="20" fill="url(#p1)"/>
            <rect x="60" y="60" width="200" height="100" rx="20" fill="url(#p2)"/>
            <text x="160" y="110" text-anchor="middle" font-family="Plus Jakarta Sans, sans-serif" font-size="22" font-weight="800" fill="white" letter-spacing="-0.5">PURAQUA</text>
            <text x="160" y="128" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="9" fill="rgba(255,255,255,.5)" letter-spacing="2">PRO SERIES</text>
            <g>
              <rect x="80" y="148" width="160" height="30" rx="8" fill="rgba(255,255,255,.08)"/>
              <rect x="84" y="152" width="20" height="22" rx="5" fill="rgba(0,200,224,.7)"/>
              <rect x="108" y="152" width="20" height="22" rx="5" fill="rgba(0,200,224,.6)"/>
              <rect x="132" y="152" width="20" height="22" rx="5" fill="rgba(0,200,224,.5)"/>
              <rect x="156" y="152" width="20" height="22" rx="5" fill="rgba(0,200,224,.4)"/>
              <rect x="180" y="152" width="20" height="22" rx="5" fill="rgba(0,200,224,.3)"/>
              <rect x="204" y="152" width="14" height="22" rx="5" fill="rgba(0,200,224,.2)"/>
              <rect x="222" y="152" width="14" height="22" rx="5" fill="rgba(0,200,224,.1)"/>
            </g>
            <circle cx="230" cy="90" r="8" fill="#10b981" opacity=".9">
              <animate attributeName="opacity" values=".9;.5;.9" dur="2s" repeatCount="indefinite"/>
            </circle>
            <rect x="100" y="196" width="120" height="80" rx="12" fill="rgba(255,255,255,.06)"/>
            <text x="160" y="222" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="10" fill="rgba(255,255,255,.5)">Caudal diario</text>
            <text x="160" y="248" text-anchor="middle" font-family="Plus Jakarta Sans, sans-serif" font-size="24" font-weight="700" fill="white">300</text>
            <text x="160" y="264" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="10" fill="rgba(0,200,224,.8)">litros / día</text>
            <rect x="140" y="320" width="40" height="16" rx="4" fill="rgba(255,255,255,.15)"/>
            <rect x="150" y="336" width="20" height="24" rx="4" fill="rgba(91,163,217,.6)"/>
            <path d="M160 368 C160 368 154 358 154 353 C154 349 157 346 160 346 C163 346 166 349 166 353 C166 358 160 368 160 368Z" fill="#00c8e0" opacity=".8">
              <animate attributeName="opacity" values=".8;.4;.8" dur="1.5s" repeatCount="indefinite"/>
            </path>
          </svg>
          <div class="product__badge-price">
            <div class="product__price-from">Precio</div>
            <div class="product__price-val">desde $14.000 <small>UYU</small></div>
          </div>
        </div>
      </div>

      <div class="product__info">
        <p class="section-label fade-up" style="color:var(--cyan);">El producto</p>
        <h2 class="product__name fade-up" id="product-h">{product.name}</h2>
        <p class="product__tagline">Purificación por Ósmosis Inversa · 7 etapas</p>
        <p class="product__desc">{product.description}</p>
        <div class="product__feats" role="list">
          <div class="product__feat" role="listitem">
            <div class="product__feat-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="9" fill="#10b981" opacity=".15"/><path d="M6 10l3 3 5-5" stroke="#10b981" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <span>7 etapas de filtración</span>
          </div>
          <div class="product__feat" role="listitem">
            <div class="product__feat-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="9" fill="#10b981" opacity=".15"/><path d="M6 10l3 3 5-5" stroke="#10b981" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <span>Membrana 0.0001 micrones — elimina 99% de contaminantes</span>
          </div>
          <div class="product__feat" role="listitem">
            <div class="product__feat-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="9" fill="#10b981" opacity=".15"/><path d="M6 10l3 3 5-5" stroke="#10b981" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <span>Filtro UV anti-bacterias</span>
          </div>
          <div class="product__feat" role="listitem">
            <div class="product__feat-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="9" fill="#10b981" opacity=".15"/><path d="M6 10l3 3 5-5" stroke="#10b981" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <span>Mineralizador — devuelve los minerales esenciales</span>
          </div>
          <div class="product__feat" role="listitem">
            <div class="product__feat-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="9" fill="#10b981" opacity=".15"/><path d="M6 10l3 3 5-5" stroke="#10b981" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <span>Tanque de almacenamiento + grifo de acero inoxidable incluidos</span>
          </div>
          <div class="product__feat" role="listitem">
            <div class="product__feat-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="9" fill="#10b981" opacity=".15"/><path d="M6 10l3 3 5-5" stroke="#10b981" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <span>Instalación guiada paso a paso por WhatsApp</span>
          </div>
        </div>
        <div class="product__specs" role="list">
          <div class="product__spec" role="listitem">
            <div class="product__spec-k">Caudal</div>
            <div class="product__spec-v">{product.specs.capacity}</div>
          </div>
          <div class="product__spec" role="listitem">
            <div class="product__spec-k">Etapas</div>
            <div class="product__spec-v">{product.specs.stages} etapas</div>
          </div>
          <div class="product__spec" role="listitem">
            <div class="product__spec-k">Dimensiones</div>
            <div class="product__spec-v">{product.specs.dimensions}</div>
          </div>
          <div class="product__spec" role="listitem">
            <div class="product__spec-k">Garantía</div>
            <div class="product__spec-v">{product.specs.warranty}</div>
          </div>
        </div>
        <div class="product__price-box">
          <div class="product__price-big">desde $14.000 <span>UYU</span></div>
          <p class="product__price-note">Precio final, sin cargos ocultos. Incluye envío a Montevideo.</p>
        </div>
        <div class="product__actions">
          <a href={buyURL} class="btn-primary" target="_blank" rel="noopener">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M11.995 0C5.375 0 0 5.372 0 11.988c0 2.113.555 4.094 1.523 5.812L0 24l6.335-1.652A11.956 11.956 0 0011.995 24C18.617 24 24 18.628 24 12.012 24 5.372 18.617 0 11.995 0zm0 21.81c-1.942 0-3.744-.52-5.295-1.42l-.379-.224-3.933 1.025 1.051-3.83-.248-.393A9.714 9.714 0 012.19 12.01c0-5.41 4.404-9.81 9.805-9.81 5.404 0 9.807 4.4 9.807 9.81 0 5.406-4.403 9.81-9.807 9.81z"/></svg>
            Comprar por WhatsApp
          </a>
          <a href="#faq" class="btn-outline">Ver preguntas frecuentes</a>
        </div>
        <div class="product__includes">
          <p class="product__includes-label">Incluye</p>
          <div class="product__includes-tags">
            {product.includes.map(item => (
              <span class="product__tag">{item}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .product { padding: 88px 0; background: var(--surface); }
  .product__inner {
    display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: start;
  }
  .product__visual {
    position: sticky; top: calc(var(--nav-h) + 24px);
    border-radius: var(--radius-lg); overflow: hidden;
    box-shadow: var(--shadow-lg);
  }
  .product__img-wrap {
    aspect-ratio: 4/5;
    background: linear-gradient(135deg, var(--blue-dark) 0%, var(--blue-medium) 60%, #1a6fa8 100%);
    display: flex; align-items: center; justify-content: center;
    position: relative; overflow: hidden;
  }
  .product__img-wrap::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse at 30% 30%, rgba(0,200,224,.15) 0%, transparent 60%);
  }
  .product__badge-price {
    position: absolute; bottom: 24px; left: 24px; right: 24px;
    background: rgba(255,255,255,.12); backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,.2); border-radius: var(--radius-md);
    padding: 16px 20px; color: var(--white);
  }
  .product__price-from { font-size: .75rem; opacity: .7; text-transform: uppercase; letter-spacing: .08em; }
  .product__price-val { font-family: var(--font-head); font-size: 1.8rem; font-weight: 800; line-height: 1; }
  .product__price-val small { font-size: .9rem; font-weight: 400; }
  .product__name { font-family: var(--font-head); font-weight: 800; font-size: 2rem; color: var(--blue-dark); margin-bottom: 8px; }
  .product__tagline { color: var(--text-muted); font-size: 1rem; margin-bottom: 16px; }
  .product__desc { color: var(--text-muted); font-size: 1rem; line-height: 1.7; margin-bottom: 24px; }
  .product__feats { margin-bottom: 28px; }
  .product__feat {
    display: flex; align-items: flex-start; gap: 12px;
    padding: 10px 0; border-bottom: 1px solid var(--border);
  }
  .product__feat:last-child { border-bottom: none; }
  .product__feat-icon { flex-shrink: 0; margin-top: 2px; }
  .product__feat span { font-size: .9rem; color: var(--text); }
  .product__specs {
    display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 32px;
  }
  .product__spec {
    background: var(--white); border: 1px solid var(--border); border-radius: var(--radius-sm);
    padding: 12px 16px;
  }
  .product__spec-k { font-size: .7rem; text-transform: uppercase; letter-spacing: .1em; color: var(--text-muted); margin-bottom: 4px; }
  .product__spec-v { font-family: var(--font-head); font-size: .95rem; font-weight: 700; color: var(--blue-dark); }
  .product__price-box {
    background: var(--surface); border-radius: var(--radius-md); padding: 20px 24px;
    border: 1px solid var(--border); margin-bottom: 16px;
  }
  .product__price-big { font-family: var(--font-head); font-size: 2.2rem; font-weight: 800; color: var(--blue-dark); line-height: 1; }
  .product__price-big span { font-size: 1.1rem; font-weight: 400; }
  .product__price-note { font-size: .82rem; color: var(--text-muted); margin-top: 6px; }
  .product__actions { display: flex; flex-direction: column; gap: 12px; margin-bottom: 20px; }
  .product__includes-label { font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: var(--text-muted); margin-bottom: 10px; }
  .product__includes-tags { display: flex; flex-wrap: wrap; gap: 8px; }
  .product__tag {
    font-size: .78rem; background: var(--surface); border: 1px solid var(--border);
    color: var(--text-muted); padding: 4px 12px; border-radius: 100px;
  }
</style>
