---
const benefits = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>`,
    title: "Mejor sabor y olor",
    desc: "Sin cloro, sin metales. El agua sabe como debe saber: limpia y natural.",
    accent: true,
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    title: "Ahorrás hasta 25x vs. embotellada",
    desc: "Un equipo Puraqua produce agua purificada a una fracción del costo del agua en botella.",
    accent: false,
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
    title: "Protegé tus electrodomésticos",
    desc: "El agua con menos minerales reduce la cal en cafeteras, hervidores y lavarropas.",
    accent: false,
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064"/></svg>`,
    title: "Menos plástico",
    desc: "Dejás de comprar botellas de un solo uso. Una pequeña acción con gran impacto ambiental.",
    accent: false,
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
    title: "Instalación simple",
    desc: "Se instala bajo la pileta en menos de una hora. Te guiamos paso a paso por WhatsApp.",
    accent: false,
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
    title: "Disponible siempre",
    desc: "Agua purificada 24/7 sin ir a comprar, sin esperar pedidos, sin quedarte sin stock.",
    accent: false,
  },
];
---

<section id="beneficios" class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-14">
      <p class="text-cyan-accent font-semibold uppercase tracking-widest text-sm mb-3">Beneficios</p>
      <h2 class="font-display text-3xl sm:text-4xl font-extrabold text-blue-dark">
        Por qué tener agua purificada<br class="hidden sm:block" /> cambia el día a día
      </h2>
    </div>

    <!-- Layout variado: primero 1 destacado + 2, luego 3 -->
    <div class="space-y-6">
      <!-- Fila 1: beneficio destacado + 2 normales -->
      <div class="grid md:grid-cols-3 gap-6">
        {benefits.slice(0, 3).map((b, i) => (
          <div class={`rounded-2xl p-7 border ${i === 0 ? 'bg-blue-dark text-white border-blue-dark col-span-1' : 'bg-surface border-blue-sky/20'}`}>
            <div class={i === 0 ? 'text-cyan-accent mb-4' : 'text-cyan-accent mb-4'}>
              <Fragment set:html={b.icon} />
            </div>
            <h3 class={`font-display font-bold text-lg mb-2 ${i === 0 ? 'text-white' : 'text-blue-dark'}`}>{b.title}</h3>
            <p class={`text-sm leading-relaxed ${i === 0 ? 'text-white/70' : 'text-text-dark/65'}`}>{b.desc}</p>
          </div>
        ))}
      </div>

      <!-- Fila 2: 3 normales -->
      <div class="grid md:grid-cols-3 gap-6">
        {benefits.slice(3).map((b) => (
          <div class="bg-surface border border-blue-sky/20 rounded-2xl p-7 hover:border-cyan-accent/30 hover:shadow-md transition-all">
            <div class="text-cyan-accent mb-4">
              <Fragment set:html={b.icon} />
            </div>
            <h3 class="font-display font-bold text-lg text-blue-dark mb-2">{b.title}</h3>
            <p class="text-sm text-text-dark/65 leading-relaxed">{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
