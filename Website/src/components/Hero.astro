---
const whatsappURL = "https://wa.me/59899000000?text=Hola%2C%20me%20interesa%20un%20equipo%20de%20ósmosis%20inversa";
---

<section class="relative min-h-screen flex items-center pt-16 overflow-hidden bg-background">
  <!-- Fondo atmosférico: ondas SVG -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <svg class="absolute bottom-0 left-0 w-full opacity-[0.04]" viewBox="0 0 1440 320" preserveAspectRatio="none">
      <path fill="#00c8e0" d="M0,192L60,181.3C120,171,240,149,360,154.7C480,160,600,192,720,197.3C840,203,960,181,1080,165.3C1200,149,1320,139,1380,133.3L1440,128L1440,320L1380,320C1320,320,1200,320,1080,320C960,320,840,320,720,320C600,320,480,320,360,320C240,320,120,320,60,320L0,320Z"></path>
    </svg>
    <svg class="absolute top-20 right-0 w-1/2 opacity-[0.03]" viewBox="0 0 600 600">
      <circle cx="300" cy="300" r="280" fill="#1a3a5c"/>
    </svg>
  </div>

  <div class="relative max-w-6xl mx-auto px-6 py-20 grid lg:grid-cols-2 gap-12 items-center">
    <!-- Texto -->
    <div class="animate-fade-up">
      <div class="inline-flex items-center gap-2 bg-cyan-accent/10 text-cyan-accent text-sm font-semibold px-4 py-1.5 rounded-full mb-6">
        <span class="w-2 h-2 bg-cyan-accent rounded-full"></span>
        Envíos a todo Uruguay
      </div>

      <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-extrabold text-blue-dark leading-tight mb-6">
        Agua pura<br />
        <span class="text-cyan-accent">en tu hogar</span><br />
        o empresa
      </h1>

      <p class="text-text-dark/70 text-lg leading-relaxed mb-8 max-w-md">
        Equipos de ósmosis inversa de calidad premium al mejor precio de Uruguay. Agua limpia, sin cloro ni contaminantes, directo de tu canilla.
      </p>

      <div class="flex flex-col sm:flex-row gap-3">
        <a
          href={whatsappURL}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center gap-2 bg-cyan-accent hover:bg-blue-light text-white font-bold px-8 py-4 rounded-xl transition-all hover:scale-[1.02] shadow-lg shadow-cyan-accent/25"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Consultar por WhatsApp
        </a>
        <a
          href="#producto"
          class="flex items-center justify-center gap-2 border-2 border-blue-dark text-blue-dark hover:bg-blue-dark hover:text-white font-bold px-8 py-4 rounded-xl transition-all"
        >
          Ver el equipo
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M12 5v14M19 12l-7 7-7-7"/>
          </svg>
        </a>
      </div>

      <!-- Badges de confianza -->
      <div class="flex flex-wrap gap-4 mt-10 text-sm text-text-dark/60">
        <div class="flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-success" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          Garantía incluida
        </div>
        <div class="flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-success" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>
          Envío a todo el país
        </div>
        <div class="flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-success" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
          Pago seguro MercadoPago
        </div>
      </div>
    </div>

    <!-- Imagen del producto -->
    <div class="flex justify-center animate-fade-up animate-fade-up-delay-2">
      <div class="relative">
        <div class="absolute inset-0 bg-gradient-to-br from-cyan-accent/20 to-blue-light/20 rounded-3xl blur-2xl scale-110"></div>
        <div class="relative bg-white rounded-3xl p-8 shadow-xl border border-surface">
          <img
            src="/images/logo.png"
            alt="Equipo de ósmosis inversa Puraqua"
            class="w-64 h-64 object-contain mx-auto"
          />
          <div class="mt-4 text-center">
            <p class="text-xs text-text-dark/50 uppercase tracking-widest font-medium">Equipo profesional</p>
            <p class="font-display font-extrabold text-2xl text-blue-dark mt-1">desde $14.000 UYU</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
