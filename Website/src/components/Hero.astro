---
import { whatsappURL } from '../data/config';

const consultURL = whatsappURL("Hola, quiero consultar sobre el Puraqua Pro");
---

<section class="hero" id="inicio">
  <!-- Background SVG decoration -->
  <svg class="hero__deco" viewBox="0 0 1200 600" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" preserveAspectRatio="xMidYMid slice">
    <defs>
      <radialGradient id="g1" cx="70%" cy="40%" r="50%">
        <stop offset="0%" stop-color="#00c8e0" stop-opacity=".18"/>
        <stop offset="100%" stop-color="#00c8e0" stop-opacity="0"/>
      </radialGradient>
    </defs>
    <circle cx="900" cy="250" r="380" fill="url(#g1)"/>
    <g stroke="#2c6faa" stroke-width="1" opacity=".25">
      <line x1="750" y1="120" x2="820" y2="180"/>
      <line x1="820" y1="180" x2="900" y2="150"/>
      <line x1="900" y1="150" x2="960" y2="220"/>
      <line x1="960" y1="220" x2="1020" y2="180"/>
      <line x1="1020" y1="180" x2="1080" y2="240"/>
      <line x1="820" y1="180" x2="780" y2="260"/>
      <line x1="780" y1="260" x2="840" y2="320"/>
      <line x1="840" y1="320" x2="920" y2="300"/>
      <line x1="920" y1="300" x2="960" y2="220"/>
      <line x1="960" y1="220" x2="1010" y2="300"/>
      <line x1="1010" y1="300" x2="1080" y2="240"/>
    </g>
    <g fill="#00c8e0" opacity=".5">
      <circle cx="750" cy="120" r="5"/>
      <circle cx="820" cy="180" r="7"/>
      <circle cx="900" cy="150" r="5"/>
      <circle cx="960" cy="220" r="9"/>
      <circle cx="1020" cy="180" r="5"/>
      <circle cx="1080" cy="240" r="6"/>
      <circle cx="780" cy="260" r="5"/>
      <circle cx="840" cy="320" r="7"/>
      <circle cx="920" cy="300" r="5"/>
      <circle cx="1010" cy="300" r="6"/>
    </g>
    <g fill="#5ba3d9" opacity=".3">
      <circle cx="850" cy="160" r="3"/>
      <circle cx="950" cy="260" r="3"/>
      <circle cx="870" cy="280" r="3"/>
      <circle cx="1000" cy="260" r="3"/>
    </g>
  </svg>

  <div class="container">
    <div class="hero__inner">
      <div class="hero__content fade-up">
        <h1 class="hero__h1">
          Agua <em>pura</em><br/>para tu hogar
        </h1>
        <p class="hero__sub">
          Comercialización, instalación y mantenimiento de equipos de ósmosis inversa. Calidad premium al mejor precio de Uruguay.
        </p>
        <div class="hero__actions">
          <a href={consultURL} class="btn-primary" target="_blank" rel="noopener" aria-label="Consultar por WhatsApp">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M11.995 0C5.375 0 0 5.372 0 11.988c0 2.113.555 4.094 1.523 5.812L0 24l6.335-1.652A11.956 11.956 0 0011.995 24C18.617 24 24 18.628 24 12.012 24 5.372 18.617 0 11.995 0zm0 21.81c-1.942 0-3.744-.52-5.295-1.42l-.379-.224-3.933 1.025 1.051-3.83-.248-.393A9.714 9.714 0 012.19 12.01c0-5.41 4.404-9.81 9.805-9.81 5.404 0 9.807 4.4 9.807 9.81 0 5.406-4.403 9.81-9.807 9.81z"/></svg>
            Consultar por WhatsApp
          </a>
          <a href="#producto" class="btn-outline">Ver el equipo</a>
        </div>
        <div class="hero__trust" role="list">
          <div class="hero__trust-item" role="listitem">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            Garantía incluida
          </div>
          <div class="hero__trust-item" role="listitem">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>
            Envío a todo el país
          </div>
          <div class="hero__trust-item" role="listitem">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
            Pago seguro MercadoPago
          </div>
        </div>
      </div>
      <div class="hero__visual fade-up fade-up-d2">
        <div class="hero__vis-wrap">
          <div class="hero__logo-glow"></div>
          <img class="hero__logo-img" src="/images/pogo-puraqua.svg" alt="PURAQUA — Purificación por Ósmosis Inversa" />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative; overflow: hidden;
    background: linear-gradient(160deg, #f8fafb 0%, #edf5fc 50%, #e0f0f9 100%);
    padding: 80px 0 60px;
  }
  .hero__deco {
    position: absolute; inset: 0; pointer-events: none; opacity: .55;
  }
  .hero__inner {
    position: relative; z-index: 1;
    display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center;
  }
  .hero__h1 {
    font-family: var(--font-head); font-weight: 800; font-size: clamp(2.2rem, 5vw, 3.6rem);
    line-height: 1.1; letter-spacing: -.03em; color: var(--blue-dark);
    margin-bottom: 20px;
  }
  .hero__h1 em { font-style: normal; color: var(--cyan); position: relative; }
  .hero__sub {
    font-size: 1.1rem; color: var(--text-muted); line-height: 1.7;
    max-width: 520px; margin-bottom: 36px;
  }
  .hero__actions { display: flex; flex-wrap: wrap; gap: 14px; align-items: center; }
  .hero__trust { display: flex; flex-wrap: wrap; gap: 20px; margin-top: 40px; padding-top: 28px; border-top: 1px solid var(--border); }
  .hero__trust-item { display: flex; align-items: center; gap: 6px; font-size: .82rem; color: var(--text-muted); }
  .hero__trust-item svg { color: var(--success); flex-shrink: 0; }
  .hero__visual {
    display: flex; justify-content: center; align-items: center;
  }
  .hero__vis-wrap {
    position: relative; display: flex; justify-content: center; align-items: center;
    width: 100%; max-width: 420px;
  }
  .hero__logo-glow {
    position: absolute;
    width: 340px; height: 340px;
    background: radial-gradient(circle, rgba(0,200,224,.18) 0%, rgba(91,163,217,.10) 50%, transparent 70%);
    border-radius: 50%;
    animation: hero-pulse 4s ease-in-out infinite;
  }
  .hero__logo-img {
    position: relative; z-index: 1;
    width: 300px; height: auto;
    filter: drop-shadow(0 16px 48px rgba(0,200,224,.30)) drop-shadow(0 4px 16px rgba(26,58,92,.20));
    animation: hero-float 5s ease-in-out infinite;
  }
  @keyframes hero-float {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-14px); }
  }
  @keyframes hero-pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50%       { transform: scale(1.08); opacity: .7; }
  }
</style>
